# Replace with your Azure App Service URL after deployment
VITE_API_URL=https://euroleague-quiz-backend-app.azurewebsites.net
# Clerk publishable key (client-safe). Injected at build time from the
# VITE_CLERK_PUBLISHABLE_KEY build env / secret; leaving it empty disables auth.
VITE_CLERK_PUBLISHABLE_KEY=
